{
  "version": 2,
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/(admin|embed)/assets/(.*)", "headers": { "cache-control": "public, max-age=31536000, immutable" } },
    { "src": "/admin", "dest": "/admin/index.html" },
    { "src": "/admin/(.*)", "dest": "/admin/index.html" },
    { "src": "/embed", "dest": "/embed/index.html" },
    { "src": "/embed/(.*)", "dest": "/embed/index.html" }
  ]
}
